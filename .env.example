# Copy this file to `.env.local` in the **project root** (one file named `.env.local`).
# Do not use a folder named `.env.local`; Vite will not load nested paths.

VITE_DATA_BACKEND=supabase

# GAS fallback (for comparison)
VITE_GAS_API_URL=
VITE_API_KEY=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PIN auth (SHA-256 of `${VITE_PIN_SALT}<4-digit-pin>`)
VITE_PIN_SHA256=
VITE_PIN_SALT=
